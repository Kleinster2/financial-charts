{
  "name": "modifyText",
  "description": "Combines text replacement/insertion and formatting in one atomic operation. Can insert text at a position, replace a range or found text, apply formatting, or any combination. Use readGoogleDoc with format='json' to determine indices.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "documentId": {
        "type": "string",
        "description": "The document ID — the long string between /d/ and /edit in a Google Docs URL."
      },
      "target": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "startIndex": {
                "type": "integer",
                "minimum": 1,
                "description": "Start of range (inclusive, 1-based)."
              },
              "endIndex": {
                "type": "integer",
                "minimum": 1,
                "description": "End of range (exclusive)."
              }
            },
            "required": [
              "startIndex",
              "endIndex"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "textToFind": {
                "type": "string",
                "minLength": 1,
                "description": "The exact text string to locate."
              },
              "matchInstance": {
                "type": "integer",
                "minimum": 1,
                "default": 1,
                "description": "Which instance of the text to target (1st, 2nd, etc.). Defaults to 1."
              }
            },
            "required": [
              "textToFind"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "insertionIndex": {
                "type": "integer",
                "minimum": 1,
                "description": "Index to insert at (1-based)."
              }
            },
            "required": [
              "insertionIndex"
            ],
            "additionalProperties": false
          }
        ],
        "description": "Target by range indices, text search, or insertion index."
      },
      "text": {
        "type": "string",
        "description": "New text to insert or replace with."
      },
      "style": {
        "type": "object",
        "properties": {
          "bold": {
            "type": "boolean",
            "description": "Apply bold formatting."
          },
          "italic": {
            "type": "boolean",
            "description": "Apply italic formatting."
          },
          "underline": {
            "type": "boolean",
            "description": "Apply underline formatting."
          },
          "strikethrough": {
            "type": "boolean",
            "description": "Apply strikethrough formatting."
          },
          "fontSize": {
            "type": "number",
            "minimum": 1,
            "description": "Set font size (in points, e.g., 12)."
          },
          "fontFamily": {
            "type": "string",
            "description": "Set font family (e.g., \"Arial\", \"Times New Roman\")."
          },
          "foregroundColor": {
            "type": "string",
            "description": "Set text color using hex format (e.g., \"#FF0000\")."
          },
          "backgroundColor": {
            "type": "string",
            "description": "Set text background color using hex format (e.g., \"#FFFF00\")."
          },
          "linkUrl": {
            "type": "string",
            "format": "uri",
            "description": "Make the text a hyperlink pointing to this URL (http or https only)."
          }
        },
        "additionalProperties": false,
        "description": "Text formatting to apply."
      },
      "tabId": {
        "type": "string",
        "description": "The ID of the specific tab to operate on. If not specified, operates on the first tab."
      }
    },
    "required": [
      "documentId",
      "target"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}