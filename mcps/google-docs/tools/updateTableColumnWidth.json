{
  "name": "updateTableColumnWidth",
  "description": "Sets fixed widths for one or more columns in an existing Google Docs table.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "documentId": {
        "type": "string",
        "description": "The document ID — the long string between /d/ and /edit in a Google Docs URL."
      },
      "tableId": {
        "type": "string",
        "minLength": 1,
        "description": "The MCP table ID returned by listDocumentTables."
      },
      "columnIndices": {
        "type": "array",
        "items": {
          "type": "integer",
          "minimum": 0
        },
        "minItems": 1,
        "description": "Zero-based column indices to update."
      },
      "widthPt": {
        "type": "number",
        "minimum": 1,
        "description": "Fixed width in points."
      },
      "tabId": {
        "type": "string",
        "description": "Optional target tab ID."
      }
    },
    "required": [
      "documentId",
      "tableId",
      "columnIndices",
      "widthPt"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}