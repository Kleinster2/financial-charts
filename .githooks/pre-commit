#!/bin/sh
set -eu

changed_files="$(git diff --cached --name-only)"

if printf '%s\n' "$changed_files" | grep -Eq '^(\.claude/skills/[^/]+/SKILL\.md|\.agents/skills/[^/]+/SKILL\.md|skills/shared-workflows\.json|scripts/(check_skill_parity|promote_shared_skill|sync_codex_skills|skill_manifest|check_note_compliance)\.py|tests/note_compliance_regression\.py|package\.json)$'; then
  echo "Consistency-sensitive files changed; checking skill parity and note-compliance regressions..."

  if ! npm run test:consistency; then
    cat <<'MSG'

Consistency check failed.
If one runtime has the intended workflow text, promote it everywhere:
  python scripts/promote_shared_skill.py SKILL --from newest
or use --from claude, --from codex, or --from openclaw when the source is explicit.

If the note-compliance regression failed, fix scripts/check_note_compliance.py
or tests/note_compliance_regression.py, then retry the commit.
MSG
    exit 1
  fi
fi

if printf '%s\n' "$changed_files" | grep -Eq '^investing/.*\.md$'; then
  echo "Investing vault notes changed; checking daily-note log..."
  python scripts/daily_note_log_gate.py --staged
fi

if printf '%s\n' "$changed_files" | grep -Eq '^investing/Events/.*\.md$'; then
  echo "Event notes changed; checking market-reaction peer coverage..."
  python scripts/check_note_compliance.py --market-reaction-peer-sweep
fi
